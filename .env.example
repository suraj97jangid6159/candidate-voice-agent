# AI Voice HR Agent - Environment Configuration
# Copy this file to .env and fill in your actual API keys

# Application Settings
APP_PORT=8000
APP_HOST=127.0.0.1
APP_DB_PATH=database.db
APP_MOCK_MODE=true

# LLM Providers
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
OPENAI_API_KEY=YOUR_OPENAI_KEY
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY
# Gemini uses OpenAI-compatible endpoint or dedicated key
GEMINI_API_KEY=YOUR_GEMINI_KEY
# Kimi/Moonshot API
KIMI_API_KEY=YOUR_KIMI_KEY

# Voice Services
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_KEY
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_KEY
PLAYHT_API_KEY=YOUR_PLAYHT_KEY
PLAYHT_USER_ID=YOUR_PLAYHT_USER_ID

# Telephony
VAPI_API_KEY=YOUR_VAPI_KEY
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_TOKEN
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TELNYX_API_KEY=YOUR_TELNYX_KEY

# Security Settings
SECURITY_STRICT_WHITELIST=true
SECURITY_BLOCK_AGREEMENTS=true
SECURITY_LOG_ALL_EVENTS=true
SECURITY_MAX_CALL_DURATION_MINUTES=30

# Notification Services (Optional)
SENDGRID_API_KEY=YOUR_SENDGRID_KEY
SENDGRID_FROM_EMAIL=noreply@voiceagent.local

# Deployment
LOG_LEVEL=INFO
ENVIRONMENT=development
